      <explain_output tag="OUTPUT" desc="Output File" value="OCP.DTA" />
      <explain_notes tag="NOTES" desc="Notes..." value="" />
      <explain_quant tag="TIMEOUT" desc="Total Time (s)" value="600" variable="None" />
      <explain_quant tag="SAMPLETIME" desc="Sample Period (s)" value="0.5" variable="None" />
