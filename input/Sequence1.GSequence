    <element>
      <name>Conditioning</name>
      <classname>CONDIT</classname>
      <type>normal</type>
      <description>Performs a Conditioning Step</description>
      <parameters>
        <explain_quant tag="TIMEOUT" desc="Time (s)" value="30" variable="None" />
        <explain_quant tag="VOLTAGE" desc="Voltage (V)" value="0.2" variable="ECSACONDI" />
        <explain_quant tag="ILIMIT" desc="ILimit (A)" value="1" variable="None" />
        <explain_toggle tag="IRCOMP" desc="IR Comp" checked="False" variable="None" />
      </parameters>
      <usecount>0</usecount>
    </element>
    <element>
      <name>Loop (Variable)</name>
      <classname>LOOPBYVARIABLE</classname>
      <type>loop_variable</type>
      <description>Causes all child experiments to be looped a until a variable meets some criteria</description>
      <parameters>
        <operator_information variable_name="scanspeed" operator="&gt;" value="100.0" valuetype="VALUE" />
      </parameters>
      <usecount>4</usecount>
      <element>
        <name>Cyclic Voltammetry</name>
        <classname>CV</classname>
        <type>normal</type>
        <description>Performs a cyclic voltammetry scan</description>
        <parameters>
          <explain_label tag="TITLE" desc="Test Identifier" value="ECSA" />
          <explain_output tag="OUTPUT" desc="Output File" value="CV_ECSA.DTA" />
          <explain_notes tag="NOTES" desc="Notes..." value="" />
          <explain_poten tag="VINIT" desc="Initial E (V)" value="0.2" versus="0" variable="ECSAPOT" />
          <explain_poten tag="VLIMIT1" desc="Scan Limit 1 (V)" value="0.3" versus="0" variable="ECSAPOTEND" />
          <explain_poten tag="VLIMIT2" desc="Scan Limit 2 (V)" value="0.2" versus="0" variable="ECSAPOT" />
          <explain_poten tag="VFINAL" desc="Final E (V)" value="0.2" versus="0" variable="ECSAPOT" />
          <explain_quant tag="SCANRATE" desc="Scan Rate (mV/s)" value="100" variable="scanspeed" />
          <explain_quant tag="STEPSIZE" desc="Step Size (mV)" value="1" variable="None" />
          <explain_iquant tag="CYCLES" desc="Cycles (#)" value="3" variable="None" />
          <explain_quant tag="AREA" desc="Sample Area (cm^2)" value="1" variable="None" />
          <explain_selector tag="IMODE" desc="I/E Range Mode" item0="Auto" item1="Fixed" index="1" />
          <explain_selector tag="SAMPLINGMODE" desc="Sampling Mode" item0="Fast" item1="Noise Reject" item2="Surface" index="2" />
          <explain_quant tag="IRANGE" desc="Max Current (mA)" value="0.4" variable="None" />
          <explain_quant tag="EQDELAY" desc="Equil. Time (s)" value="0" variable="None" />
          <explain_selector tag="IRCOMP" desc="IRComp" item0="None" item1="PF" item2="CI" index="0" />
          <explain_quant tag="PFCOR" desc="PF Corr. (ohm)" value="50" variable="None" />
        </parameters>
        <usecount>6</usecount>
      </element>
      <element>
        <name>Modify Variable</name>
        <type>modify_variable</type>
        <description>Allows the user to modify a variable that has already been created.</description>
        <parameters>
          <modifier_information variable_name="scanspeed" modifier="+" value="10.0" valuetype="VALUE" />
        </parameters>
        <usecount>5</usecount>
      </element>
