    </parameters>
    <usecount>7</usecount>
    <element>
      <name>Cyclic Voltammetry</name>
      <classname>CV</classname>
      <type>normal</type>
      <description>Performs a cyclic voltammetry scan</description>
      <parameters>
        <explain_label tag="TITLE" desc="Test Identifier" value="Cyclic Voltammetry" />
        <explain_output tag="OUTPUT" desc="Output File" value="MYCIE.DTA" />
        <explain_notes tag="NOTES" desc="Notes..." value="STYK = 1 Ohm&#xD;&#xA;0.5 M H2SO4, V = 225 mL&#xD;&#xA;AM Reference (0.228 vs RHE - niesprawdzane)" />
        <explain_poten tag="VINIT" desc="Initial E (V)" value="-0.5" versus="0" variable="None" />
        <explain_poten tag="VLIMIT1" desc="Scan Limit 1 (V)" value="0.3" versus="0" variable="None" />
        <explain_poten tag="VLIMIT2" desc="Scan Limit 2 (V)" value="-0.5" versus="0" variable="None" />
        <explain_poten tag="VFINAL" desc="Final E (V)" value="-0.5" versus="0" variable="None" />
        <explain_quant tag="SCANRATE" desc="Scan Rate (mV/s)" value="200" variable="None" />
        <explain_quant tag="STEPSIZE" desc="Step Size (mV)" value="1" variable="None" />
        <explain_iquant tag="CYCLES" desc="Cycles (#)" value="20" variable="None" />
        <explain_quant tag="AREA" desc="Sample Area (cm^2)" value="1" variable="None" />
        <explain_selector tag="IMODE" desc="I/E Range Mode" item0="Auto" item1="Fixed" index="0" />
        <explain_selector tag="SAMPLINGMODE" desc="Sampling Mode" item0="Fast" item1="Noise Reject" item2="Surface" index="1" />
        <explain_quant tag="IRANGE" desc="Max Current (mA)" value="0.3" variable="None" />
        <explain_quant tag="EQDELAY" desc="Equil. Time (s)" value="0" variable="None" />
        <explain_selector tag="IRCOMP" desc="IRComp" item0="None" item1="PF" item2="CI" index="0" />
        <explain_quant tag="PFCOR" desc="PF Corr. (ohm)" value="50" variable="None" />
      </parameters>
      <usecount>25</usecount>
    </element>
    <element>
      <name>Loop (Cycle)</name>
      <classname>LOOPBYCYCLE</classname>
      <type>loop</type>
      <description>Causes all child experiments to be looped a user specified number of times</description>
      <parameters>
        <explain_iquant tag="LOOPCOUNT" desc="Loop Count (#)" value="3" variable="None" />
      </parameters>
      <usecount>4</usecount>
      <element>
        <name>Get Ru</name>
        <classname>GETRU</classname>
        <type>normal</type>
        <description>Performs Ru Estimation</description>
        <parameters>
          <explain_poten tag="VDC" desc="DC Voltage (V)" value="0.15" versus="0" variable="EISECSAPOT" />
          <explain_quant tag="ZGUESS" desc="Estimated Z (ohms)" value="20" variable="None" />
        </parameters>
        <usecount>3</usecount>
      </element>
    </element>
