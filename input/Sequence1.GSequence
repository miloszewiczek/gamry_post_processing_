      <description>Performs an impedance scan under potentiostatic control</description>
      <parameters>
        <explain_label tag="TITLE" desc="Test Identifier" value="EIS_ECSA" />
        <explain_output tag="OUTPUT" desc="Output File" value="EIS_ECSA.DTA" />
        <explain_notes tag="NOTES" desc="Notes..." value="" />
        <explain_poten tag="VDC" desc="DC Voltage (V)" value="0" versus="0" variable="EISECSAPOT" />
        <explain_quant tag="FREQINIT" desc="Initial Freq. (Hz)" value="100000" variable="None" />
        <explain_quant tag="FREQFINAL" desc="Final Freq. (Hz)" value="0.1" variable="None" />
        <explain_quant tag="PTSPERDEC" desc="Points/decade" value="10" variable="None" />
        <explain_quant tag="VAC" desc="AC Voltage (mV rms)" value="10" variable="None" />
        <explain_quant tag="AREA" desc="Sample Area (cm^2)" value="1" variable="None" />
        <explain_quant tag="ZGUESS" desc="Estimated Z (ohms)" value="100" variable="None" />
        <explain_selector tag="SPEED" desc="Optimize for:" item0="Fast" item1="Normal" item2="Low Noise" index="1" />
        <explain_selector tag="THD" desc="THD" item0="Off" item1="On" index="0" />
        <explain_selector tag="DRIFTCOR" desc="Drift Correction" item0="Off" item1="On" index="0" />
      </parameters>
      <usecount>9</usecount>
    </element>
    <element>
      <name>Modify Variable</name>
      <type>modify_variable</type>
